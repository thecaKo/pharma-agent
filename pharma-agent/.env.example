PHARMA_PANEL_URL=http://localhost:3000
PHARMA_AGENT_SETUP_HOST=127.0.0.1
PHARMA_AGENT_SETUP_PORT=3333
# Optional. Linux only. Agent sets this automatically when omitted.
# FIREBIRD_LOCK=/tmp/pharma-firebird-lock
# Optional. Use "node" to force node-firebird instead of isql-fb fallback.
# PHARMA_FIREBIRD_DRIVER=isql
# Optional. Explicit isql binary path.
# PHARMA_FIREBIRD_ISQL=/usr/bin/isql-fb
